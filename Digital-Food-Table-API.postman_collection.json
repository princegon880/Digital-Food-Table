    {
      "name": "Authentication & Profile (Private)",
      "item": [
        {
          "name": "Sync Clerk Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantName\": \"Cafe Aroma\",\n  \"email\": \"cafe.aroma@example.com\",\n  \"phoneNumber\": \"9409928290\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sync-profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "sync-profile"
              ]
            },
            "description": "Syncs the authenticated Clerk user details with the database profiles table. Creates a profile if it doesn't exist, generates a slug, and links the ID."
          },
          "response": []
        },
        {
          "name": "Get Current User Details (Me)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Fetches the current user profile metadata. Incorporates a self-healing fallback that automatically creates a default profile if the authenticated user doesn't have one."
          },
          "response": []
        },

    {
      "name": "Diagnostics & Utilities",
      "item": [
        {
          "name": "Test Database connection",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/test-db",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "test-db"
              ]
            },
            "description": "Checks whether the database is connected to the official online Supabase project or running in local offline db.json mode, and runs test queries on profiles, categories, and menu items."
          },
          "response": []
